#include <iostream>
#include <vector>
#include <chrono>
#include <cstdlib>
using namespace std;

// binary heap

class BinaryHeap {
    vector<int> heap;

public:
    void insert(int x) {
        heap.push_back(x);
        int i = heap.size() - 1;

        while (i > 0 && heap[(i - 1) / 2] > heap[i]) {
            swap(heap[i], heap[(i - 1) / 2]);
            i = (i - 1) / 2;
        }
    }

    int getMin() {
        return heap[0];
    }

    void deleteMin() {
        heap[0] = heap.back();
        heap.pop_back();

        int i = 0;
        int n = heap.size();

        while (2 * i + 1 < n) {
            int left = 2 * i + 1;
            int right = 2 * i + 2;
            int smallest = left;

            if (right < n && heap[right] < heap[left])
                smallest = right;

            if (heap[i] <= heap[smallest]) break;

            swap(heap[i], heap[smallest]);
            i = smallest;
        }
    }

    bool empty() {
        return heap.empty();
    }
};

// binomial heap

struct BNode {
    int key, degree;
    BNode *child, *sibling;

    BNode(int k) {
        key = k;
        degree = 0;
        child = sibling = nullptr;
    }
};

class BinomialHeap {
    BNode* head = nullptr;

    BNode* merge(BNode* h1, BNode* h2) {
        if (!h1) return h2;
        if (!h2) return h1;

        if (h1->key > h2->key) swap(h1, h2);

        h2->sibling = h1->child;
        h1->child = h2;
        h1->degree++;

        return h1;
    }

public:
    void insert(int x) {
        BNode* node = new BNode(x);
        head = merge(head, node);
    }

    int getMin() {
        return head->key;
    }

    void deleteMin() {
        if (!head) return;

        BNode* temp = head->child;
        head = nullptr;

        while (temp) {
            BNode* next = temp->sibling;
            temp->sibling = nullptr;
            head = merge(head, temp);
            temp = next;
        }
    }

    bool empty() {
        return head == nullptr;
    }
};

// pairing heap

struct PNode {
    int key;
    PNode* child;
    PNode* sibling;

    PNode(int k) {
        key = k;
        child = sibling = nullptr;
    }
};

class PairingHeap {
    PNode* root = nullptr;

    PNode* merge(PNode* a, PNode* b) {
        if (!a) return b;
        if (!b) return a;

        if (b->key < a->key) swap(a, b);

        b->sibling = a->child;
        a->child = b;
        return a;
    }

public:
    void insert(int x) {
        root = merge(root, new PNode(x));
    }

    int getMin() {
        return root->key;
    }

    void deleteMin() {
        if (!root) return;

        PNode* temp = root->child;
        root = nullptr;

        while (temp) {
            PNode* next = temp->sibling;
            temp->sibling = nullptr;
            root = merge(root, temp);
            temp = next;
        }
    }

    bool empty() {
        return root == nullptr;
    }
};

// testing

void testAll() {
    const int N = 10000;
    vector<int> values;

    for (int i = 0; i < N; i++)
        values.push_back(rand());

    BinaryHeap bh;
    BinomialHeap bih;
    PairingHeap ph;

    // test binary
    auto start = chrono::high_resolution_clock::now();
    for (int x : values) bh.insert(x);
    while (!bh.empty()) bh.deleteMin();
    auto end = chrono::high_resolution_clock::now();
    cout << "Binary Heap Time: "
         << chrono::duration<double>(end - start).count() << endl;

    // test binomial
    start = chrono::high_resolution_clock::now();
    for (int x : values) bih.insert(x);
    while (!bih.empty()) bih.deleteMin();
    end = chrono::high_resolution_clock::now();
    cout << "Binomial Heap Time: "
         << chrono::duration<double>(end - start).count() << endl;

    // test pairing
    start = chrono::high_resolution_clock::now();
    for (int x : values) ph.insert(x);
    while (!ph.empty()) ph.deleteMin();
    end = chrono::high_resolution_clock::now();
    cout << "Pairing Heap Time: "
         << chrono::duration<double>(end - start).count() << endl;
}

// main

int main() {
    testAll();
    return 0;
}

